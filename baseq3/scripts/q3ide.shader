q3ide/mirror
{
    portal
    {
        map $whiteimage
        blendFunc GL_ZERO GL_ONE
        depthWrite
    }
}

q3ide/border
{
    nomipmaps
    nopicmip
    {
        map $whiteimage
        depthwrite
        rgbGen vertex
    }
}

q3ide/win0
{
    nomipmaps
    nopicmip
    {
        map *scratch0
        depthwrite
        rgbGen vertex
    }
}

