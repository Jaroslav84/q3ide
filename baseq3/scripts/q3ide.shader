q3ide/mirror
{
    portal
    {
        map $whiteimage
        blendFunc GL_ZERO GL_ONE
        depthWrite
    }
}

q3ide/border
{
    nomipmaps
    nopicmip
    {
        map $whiteimage
        depthWrite
        rgbGen vertex
    }
}

