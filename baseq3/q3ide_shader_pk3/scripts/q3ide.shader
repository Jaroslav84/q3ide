q3ide/mirror
{
    portal
    {
        map $white
        blendFunc GL_ZERO GL_ONE
        depthWrite
    }
}

q3ide/border
{
    nomipmaps
    nopicmip
    {
        map $white
        depthWrite
        rgbGen vertex
    }
}

